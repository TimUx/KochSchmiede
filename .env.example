# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=secret

# JWT secret key (REQUIRED — use: openssl rand -hex 32)
SECRET_KEY=

# Optional: your domain and port for CORS.
# Set DOMAIN to the hostname your browser uses to reach the app and PORT to
# the public port (e.g. from a reverse proxy).  Both are used to build the
# CORS_ORIGINS list so the browser accepts API responses.
# Example (behind a reverse proxy on port 3003):
#   DOMAIN=server
#   PORT=3003
DOMAIN=localhost
PORT=3000

# ── KI-gestützte Rezept-Erkennung (kostenlos / lokal) ────────────────────────
#
# Der Import-Prozess nutzt eine dreistufige Kette:
#   1. Vision-KI  – Bild / gerenderte PDF-Seite direkt an das Modell senden
#                   (beste Ergebnisse bei Tabellen, Spalten, Grids)
#   2. Text-KI    – OCR-Text an das LLM senden
#   3. Heuristik  – integrierter Regex-Parser, immer verfügbar, keine Konfig
#
# Wähle eine der kostenlosen Optionen unten.
#
# ── Option A: Ollama mit Vision-Modell (beste Qualität) ──────────────────────
#
# 1. Stack mit Ollama starten:
#    docker compose --profile ollama up -d
#
# 2. Vision-Modell herunterladen (einmalig):
#    docker compose exec ollama ollama pull llama3.2-vision
#
# 3. In dieser Datei aktivieren:
#LLM_BASE_URL=http://ollama:11434/v1
#LLM_MODEL=llama3.2-vision
#
# ── Option B: Ollama mit Text-Modell + Tesseract OCR (ressourcenschonend) ────
#
# Statt eines großen Vision-Modells nutzt diese Option Tesseract OCR (läuft
# lokal im Backend-Container, CPU-only) zum Text-Extrahieren aus Bildern und
# PDFs.  Das deutlich kleinere Text-LLM strukturiert dann nur den Text.
# → weniger RAM/VRAM, schnellere Ladezeit, keine GPU erforderlich
#
# 1. Stack mit Ollama starten:
#    docker compose --profile ollama up -d
#
# 2. Text-Modell herunterladen (einmalig):
#    docker compose exec ollama ollama pull llama3.2
#
# 3. In dieser Datei aktivieren:
#LLM_BASE_URL=http://ollama:11434/v1
#LLM_MODEL=llama3.2
#LLM_VISION=false
#
# ── Option C: LM Studio (lokal, kostenlos, Desktop-App) ──────────────────────
#
# 1. LM Studio herunterladen: https://lmstudio.ai
# 2. Ein Modell laden (z.B. llama-3.2-vision oder llava)
# 3. Lokalen Server in LM Studio starten
# 4. In dieser Datei aktivieren:
#LLM_BASE_URL=http://host.docker.internal:1234/v1
#LLM_MODEL=dein-geladenes-modell
#
# ── Option D: Legacy Ollama /api/generate (Abwärtskompatibilität) ─────────────
# Bevorzuge Option A oder B für neue Installationen.
#AI_ENDPOINT=http://ollama:11434
#AI_MODEL=llama3.2

# Aktive Werte (eine der Optionen oben einkommentieren/ausfüllen):
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=llama3.2
# LLM_VISION=true   → Vision-Modell verwenden (Standard)
# LLM_VISION=false  → Tesseract OCR + Text-LLM (Option B, ressourcenschonend)
LLM_VISION=true
AI_ENDPOINT=
AI_MODEL=llama3.2

# Timeout in seconds per LLM inference call (default: 300).
# Increase this value on CPU-only hardware where models are slow.
# Example: AI_TIMEOUT=600
AI_TIMEOUT=300
