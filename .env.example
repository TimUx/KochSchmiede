# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=secret

# JWT secret key (REQUIRED — use: openssl rand -hex 32)
SECRET_KEY=

# Optional: your domain for CORS
DOMAIN=localhost

# Optional: AI-assisted recipe parsing via an Ollama-compatible LLM server.
# Leave AI_ENDPOINT empty (default) to disable AI parsing and use only
# the built-in heuristic parser.
# Example: AI_ENDPOINT=http://ollama:11434
AI_ENDPOINT=
AI_MODEL=llama3.2
