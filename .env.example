# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=secret

# JWT secret key (REQUIRED — use: openssl rand -hex 32)
SECRET_KEY=

# Optional: your domain and port for CORS.
# Set DOMAIN to the hostname your browser uses to reach the app and PORT to
# the public port (e.g. from a reverse proxy).  Both are used to build the
# CORS_ORIGINS list so the browser accepts API responses.
# Example (behind a reverse proxy on port 3003):
#   DOMAIN=server
#   PORT=3003
DOMAIN=localhost
PORT=3000

# ── KI-gestützte Rezept-Erkennung (kostenlos / lokal) ────────────────────────
#
# Der Import-Prozess analysiert jedes Dokument selbst und wählt automatisch
# die schnellste und ressourcenschonendste KI-Strategie:
#
#   1. Strukturiertes PDF / gute OCR-Qualität → schnelles Text-LLM
#   2. Bild mit schlechter OCR-Qualität (Zeitschrift, Handschrift, mehrspaltig)
#      → Vision-LLM (Bild direkt an das Modell)
#   3. Heuristik-Parser – integriert, immer als Fallback verfügbar
#
# Wenn Ollama verfügbar ist, werden die benötigten Modelle beim ersten Import
# automatisch heruntergeladen (OLLAMA_AUTO_PULL=true):
#   • llama3.2   (~2 GB) – schnelles Text-Modell
#   • llava:7b   (~4.7 GB) – gutes Vision-Modell
#
# ── Option A: Ollama – vollautomatisch (empfohlen) ───────────────────────────
#
# 1. Stack mit Ollama starten:
#    docker compose --profile ollama up -d
#
# 2. Nur noch LLM_BASE_URL setzen – Modelle werden automatisch geladen:
#LLM_BASE_URL=http://ollama:11434/v1
#
# ── Option B: Ollama mit manuell festgelegtem Modell ─────────────────────────
#
# Wenn du ein bestimmtes Modell erzwingen möchtest (z.B. ein sehr kleines
# Text-Modell auf schwacher Hardware):
#LLM_BASE_URL=http://ollama:11434/v1
#LLM_MODEL=llama3.2:1b
#
# Um Vision komplett zu deaktivieren (nur Text-LLM + Tesseract OCR):
#LLM_BASE_URL=http://ollama:11434/v1
#LLM_MODEL=llama3.2
#LLM_VISION=false
#
# ── Option C: LM Studio (lokal, kostenlos, Desktop-App) ──────────────────────
#
# Bei LM Studio ist immer nur ein Modell gleichzeitig geladen → LLM_MODEL muss
# manuell gesetzt werden.
#
# 1. LM Studio herunterladen: https://lmstudio.ai
# 2. Ein Modell laden (z.B. llava:7b für Vision oder llama3.2 für Text)
# 3. Lokalen Server in LM Studio starten
# 4. In dieser Datei aktivieren:
#LLM_BASE_URL=http://host.docker.internal:1234/v1
#LLM_MODEL=dein-geladenes-modell
#
# ── Option D: Legacy Ollama /api/generate (Abwärtskompatibilität) ─────────────
# Bevorzuge Option A oder B für neue Installationen.
#AI_ENDPOINT=http://ollama:11434
#AI_MODEL=llama3.2

# Aktive Werte (LLM_BASE_URL einkommentieren und den Rest nach Bedarf anpassen):
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=          # leer = automatische Modellauswahl aus Ollama
# LLM_VISION=true   # true  = Vision immer erzwingen (nützlich bei ungewöhnlichen Modellnamen)
                    # false = Vision vollständig deaktivieren (nur Text-LLM + OCR)
                    # leer  = automatisch (Standard): Vision-fähige Modelle werden
                    #         anhand des Modellnamens erkannt oder aus Ollama ermittelt.
                    #         Auch wenn LLM_MODEL auf ein Text-Modell gesetzt ist (z.B.
                    #         llama3.2), wird automatisch nach einem separaten Vision-
                    #         Modell gesucht (z.B. llava:7b).
AI_ENDPOINT=
AI_MODEL=llama3.2

# Automatisches Herunterladen von Modellen beim Start (Standard: aktiviert).
# Setze auf false, um die Modellverwaltung manuell zu übernehmen.
OLLAMA_AUTO_PULL=true

# Timeout in seconds per LLM inference call (default: 300).
# Increase this value on CPU-only hardware where models are slow.
# Example: AI_TIMEOUT=600
AI_TIMEOUT=300

# ── Bildersuche beim Import ───────────────────────────────────────────────────
# Wenn ein importiertes Rezept kein Bild hat, kann die Import-Seite passende
# Fotos online suchen und zur Auswahl anbieten.
#
# Es können mehrere Anbieter (kommagetrennt) angegeben werden – sie werden der
# Reihe nach ausprobiert, bis einer Ergebnisse liefert.
#
# Unterstützte Anbieter:
#   pixabay  – Kostenlos, 500 Anfragen/h: https://pixabay.com/api/docs/
#   unsplash – Kostenlos, 50 Anfragen/h:  https://unsplash.com/developers
#   pexels   – Kostenlos, 200 Anfragen/h: https://www.pexels.com/api/
#
# Nur Anbieter mit einem gesetzten API-Schlüssel werden genutzt.
# Die Funktion ist deaktiviert, wenn kein Schlüssel gesetzt ist.
IMAGE_SEARCH_PROVIDER=pixabay,unsplash,pexels
PIXABAY_API_KEY=
UNSPLASH_API_KEY=
PEXELS_API_KEY=
# Veraltet: IMAGE_SEARCH_API_KEY wird als Pixabay-Schlüssel verwendet,
# wenn PIXABAY_API_KEY nicht gesetzt ist.
IMAGE_SEARCH_API_KEY=
