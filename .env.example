# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=secret

# JWT secret key (REQUIRED — use: openssl rand -hex 32)
SECRET_KEY=

# Optional: your domain and port for CORS.
# Set DOMAIN to the hostname your browser uses to reach the app and PORT to
# the public port (e.g. from a reverse proxy).  Both are used to build the
# CORS_ORIGINS list so the browser accepts API responses.
# Example (behind a reverse proxy on port 3003):
#   DOMAIN=server
#   PORT=3003
DOMAIN=localhost
PORT=3000

# ── AI-assisted recipe parsing ────────────────────────────────────────────────
#
# The import process uses a three-level fallback chain:
#   1. Vision AI  – sends the image / rendered PDF page directly to a
#                   vision-capable model (best for tables, columns, grids)
#   2. Text AI    – OCR text is sent to an LLM for structured extraction
#   3. Heuristic  – built-in regex parser, always available, no config needed
#
# Choose ONE of the options below (or combine them; priority is as above).
#
# ── Option A: OpenAI (best quality, paid) ─────────────────────────────────────
# GPT-4o-mini supports both text and vision.
#OPENAI_API_KEY=sk-...
#OPENAI_BASE_URL=https://api.openai.com/v1
#OPENAI_MODEL=gpt-4o-mini

# ── Option B: Groq (fast, generous free tier, text-only models) ───────────────
#OPENAI_API_KEY=gsk_...
#OPENAI_BASE_URL=https://api.groq.com/openai/v1
#OPENAI_MODEL=llama-3.1-8b-instant

# ── Option C: Ollama (local / free, runs on your own machine or server) ────────
# Start the bundled Ollama service:  docker compose --profile ollama up
# Then pull a model:                 docker compose exec ollama ollama pull llama3.2
# For vision support pull:           docker compose exec ollama ollama pull llama3.2-vision
#OPENAI_BASE_URL=http://ollama:11434/v1
#OPENAI_MODEL=llama3.2
# (no OPENAI_API_KEY needed for local Ollama)

# ── Option D: LM Studio (local / free, desktop app) ──────────────────────────
#OPENAI_BASE_URL=http://host.docker.internal:1234/v1
#OPENAI_MODEL=your-loaded-model-name

# ── Option E: Legacy Ollama /api/generate (backwards compatibility) ───────────
# Prefer Option C above for new setups.
#AI_ENDPOINT=http://ollama:11434
#AI_MODEL=llama3.2

# Active values (uncomment/fill the option you chose above):
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_ENDPOINT=
AI_MODEL=llama3.2
